          "entrypoint": "architect",
          "model": "gpt-5.4",
          "reasoning_effort": "high"
        },
        "developer": {
          "mode": "agent",
          "entrypoint": "developer",
          "model": "gpt-5.4",
          "reasoning_effort": "medium"
        },
        "auditor": {
          "mode": "agent",
          "entrypoint": "auditor",
          "model": "gpt-5.4",
          "reasoning_effort": "high"
        }
      },
      "notes": "Perfil padrão para o loop Architect -> Developer -> Auditor via Codex CLI externo."
    },
    "codex-fast-feedback": {
      "engine": "openai-codex-cli",
      "command": "codex",
